# AXIS System — Environment Variables Template
# Copia este archivo como .env.local y completa los valores

# ===========================================
# BASE DE DATOS POSTGRESQL (REQUERIDO)
# ===========================================
# Cadena de conexión a PostgreSQL en Dokploy
# Formato: postgresql://usuario:password@host:puerto/nombre_db
DATABASE_URL=postgresql://usuario:password@host:5432/axis_db

# ===========================================
# VERCEL BLOB STORAGE (REQUERIDO para adjuntos)
# ===========================================
BLOB_READ_WRITE_TOKEN=tu_vercel_blob_token_aqui

# ===========================================
# GOOGLE GEMINI AI (OPCIONAL)
# Sin esto, no habrá categorización automática de tickets
# ===========================================
GOOGLE_GENAI_API_KEY=tu_gemini_api_key_aqui
GEMINI_API_KEY=tu_gemini_api_key_aqui

# ===========================================
# EMAIL — SMTP Hostinger (REQUERIDO para OTP)
# ===========================================
HOSTINGER_EMAIL_USER=tu_email@hostinger.com
HOSTINGER_EMAIL_PASS=tu_password_email

# ===========================================
# WHATSAPP BOT (OPCIONAL)
# ===========================================
WHATSAPP_BOT_API_KEY=axis-whatsapp-bot-2024
AXIS_BOT_API_KEY=anthon2026_etc*

# ===========================================
# DEVELOPMENT / PRODUCTION
# ===========================================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===========================================
# NOTAS
# ===========================================
# 1. DATABASE_URL es REQUERIDO — apunta a PostgreSQL en Dokploy
# 2. Ejecutar scripts/schema.sql en la BD antes del primer deploy
# 3. Sin BLOB_READ_WRITE_TOKEN los adjuntos no funcionarán
# 4. Sin EMAIL, el login OTP no enviará correos
# 5. En producción, cambiar NEXT_PUBLIC_APP_URL por el dominio real
